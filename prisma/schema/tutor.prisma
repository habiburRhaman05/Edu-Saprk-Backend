model TutorProfile {
  id           String         @id @default(uuid())
  userId       String         @unique
  bio          String
  hourlyRate   Int
  experience   String
  subjects     String[]
  categoryId   String
  category     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  availability Availability[]
  bookings     Booking[]
  user         User           @relation(fields: [userId], references: [id])
}